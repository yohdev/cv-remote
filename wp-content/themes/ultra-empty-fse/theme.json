        },
        {
          "slug": "base",
          "color": "#ffffff",
          "name": "Base"
        },
        {
          "slug": "base-2",
          "color": "#f7f7f7",
          "name": "Base 2"
        },
        {
          "slug": "accent",
          "color": "#0065d1",
          "name": "Accent"
