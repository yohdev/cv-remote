# ===========================================
# WordPress Core (managed by Studio, not us)
# ===========================================
/wp-admin/
/wp-includes/
/wp-*.php
/index.php
/license.txt
/readme.html
/xmlrpc.php
/available-site-translations.json

# Keep wp-config.php tracked (has site-specific salts and settings)
!wp-config.php

# ===========================================
# wp-content: Only track custom code
# ===========================================

# Ignore everything in wp-content by default
wp-content/*

# Then whitelist our custom plugins
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/custom-functions/
!wp-content/plugins/custom-scripts/
!wp-content/plugins/custom-styles/
!wp-content/plugins/design-variables/
!wp-content/plugins/custom-front-admin-bar-master/
!wp-content/plugins/acf-core-master/

# Whitelist our custom theme
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/ultra-empty-fse/

# ===========================================
# Never track these
# ===========================================

# Uploads (media files — too large for git)
wp-content/uploads/

# Database
*.sql
*.sqlite
wp-content/database/

# Studio SQLite integration (managed by Studio)
wp-content/mu-plugins/

# Debug logs
wp-content/debug.log

# OS files
.DS_Store
Thumbs.db

# Environment / local config
.env
wp-config-local.php

# Dependencies
node_modules/
vendor/

# Upgrade artifacts
wp-content/upgrade/
wp-content/upgrade-temp-backup/

# Cache
wp-content/advanced-cache.php
wp-content/cache/
